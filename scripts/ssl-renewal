#!/usr/bin/env bash
set -euo pipefail

SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -f /opt/ssl-renewal/lib.sh ]]; then
  # shellcheck disable=SC1091
  source /opt/ssl-renewal/lib.sh
elif [[ -f "${SELF_DIR}/lib.sh" ]]; then
  # shellcheck disable=SC1091
  source "${SELF_DIR}/lib.sh"
else
  echo "lib.sh not found (checked /opt/ssl-renewal/lib.sh and ${SELF_DIR}/lib.sh)" >&2
  exit 1
fi

CONFIG_LOADED=0
ensure_config_loaded() {
  [[ "$CONFIG_LOADED" -eq 1 ]] && return 0
  load_config
  CONFIG_LOADED=1
}

usage() {
cat <<'USAGE'
Usage:
  ssl-renewal help
  ssl-renewal doctor
  ssl-renewal status
  ssl-renewal start
  ssl-renewal stop
  ssl-renewal restart
  ssl-renewal reload
  ssl-renewal enable
  ssl-renewal disable
  ssl-renewal issue
  ssl-renewal dry-run
  ssl-renewal deploy
  ssl-renewal notify-test
  ssl-renewal edit-config
  ssl-renewal paths
  ssl-renewal patch-nginx [--apply]
  ssl-renewal disable-node-renew
  ssl-renewal cloudflare-help
USAGE
}

require_role_main() { [[ "${ROLE}" == "main" ]] || { echo "This command is available only on main." >&2; exit 1; }; }

do_status() {
  ensure_config_loaded
  banner
  echo
  echo "ROLE: ${ROLE}"
  show_paths
  echo
  if [[ -f "${CERT_DIR}/fullchain.pem" ]]; then
    echo "--- Certificate ---"
    openssl x509 -in "${CERT_DIR}/fullchain.pem" -noout -subject -issuer -dates || true
  else
    echo "Certificate not found yet: ${CERT_DIR}/fullchain.pem"
  fi
  echo
  echo "--- Nginx ---"
  systemctl is-active nginx 2>/dev/null || true
  nginx -t 2>/dev/null || true
  echo
  echo "--- Certbot timers ---"
  systemctl list-timers | grep certbot || true
}

do_start() { ensure_config_loaded; require_role_main; local timer; timer="$(detect_certbot_timer_unit)"; [[ -n "$timer" ]] || { echo "Certbot timer not found." >&2; exit 1; }; systemctl start "$timer"; systemctl status "$timer" --no-pager || true; }
do_stop() { ensure_config_loaded; require_role_main; local timer; timer="$(detect_certbot_timer_unit)"; [[ -n "$timer" ]] || { echo "Certbot timer not found." >&2; exit 1; }; systemctl stop "$timer"; }
do_enable() { ensure_config_loaded; require_role_main; local timer; timer="$(detect_certbot_timer_unit)"; [[ -n "$timer" ]] || { echo "Certbot timer not found." >&2; exit 1; }; systemctl enable "$timer"; }

do_disable() {
  ensure_config_loaded
  if [[ "${ROLE}" == "main" ]]; then
    local timer
    timer="$(detect_certbot_timer_unit)"
    [[ -n "$timer" ]] || { echo "Certbot timer not found." >&2; exit 1; }
    systemctl disable --now "$timer"
  else
    /opt/ssl-renewal/node-prep.sh --disable-renew-only
  fi
}

do_restart() { ensure_config_loaded; require_role_main; local service timer; service="$(detect_certbot_service_unit)"; timer="$(detect_certbot_timer_unit)"; [[ -n "$service" ]] && systemctl restart "$service" || true; [[ -n "$timer" ]] && systemctl restart "$timer" || true; }
do_reload() { systemctl reload nginx; echo "nginx reloaded"; }
do_issue() { ensure_config_loaded; require_role_main; run_issue; }
do_dry_run() { ensure_config_loaded; require_role_main; certbot renew --dry-run; }
do_deploy() { ensure_config_loaded; require_role_main; /opt/ssl-renewal/deploy-certs.sh; }
do_notify_test() { ensure_config_loaded; notify_tg "✅ <b>SSL Renewal</b>%0AHost: <code>$(hostname -f 2>/dev/null || hostname)</code>%0AMessage: test notification"; echo "Notification requested"; }

do_doctor() {
  ensure_config_loaded
  if [[ "${ROLE}" == "main" ]]; then
    doctor_main && echo "doctor: OK" || { echo "doctor: FAIL"; exit 1; }
  else
    doctor_node && echo "doctor: OK" || { echo "doctor: FAIL"; exit 1; }
  fi
}

do_edit_config() { ensure_config_loaded; "${EDITOR:-nano}" /etc/ssl-renewal/config.env; }
do_patch_nginx() { /opt/ssl-renewal/node-nginx-patch.sh "$@"; }
do_disable_node_renew() { /opt/ssl-renewal/node-prep.sh --disable-renew-only; }

do_cloudflare_help() {
  local primary_domain="${PRIMARY_DOMAIN:-example.com}"
  local creds_file="${CLOUDFLARE_CREDENTIALS:-/root/.secrets/certbot/cloudflare.ini}"
  cat <<EOF2
Cloudflare API Token quick guide:
  The same token must have DNS Edit and Zone Read access for all zones/domains in the certificate.
  1. Open Cloudflare Dashboard
  2. Go to My Profile -> API Tokens -> Create Token
  3. Minimum permissions:
       Zone -> DNS -> Edit
       Zone -> Zone -> Read
  4. Restrict token to every zone used by this install. Include ${primary_domain} and any EXTRA_DOMAINS_CSV zones.
     Examples: example.com, example.net, example.org
  5. Save token in:
       ${creds_file}
     as:
       dns_cloudflare_api_token = YOUR_TOKEN

Then run:
  ssl-renewal doctor
  ssl-renewal issue
EOF2
}

cmd="${1:-help}"
shift || true

case "$cmd" in
  help|-h|--help) usage ;;
  cloudflare-help) do_cloudflare_help ;;
  doctor) do_doctor ;;
  status) do_status ;;
  start) do_start ;;
  stop) do_stop ;;
  restart) do_restart ;;
  reload) do_reload ;;
  enable) do_enable ;;
  disable) do_disable ;;
  issue) do_issue ;;
  dry-run) do_dry_run ;;
  deploy) do_deploy ;;
  notify-test) do_notify_test ;;
  edit-config) do_edit_config ;;
  paths) ensure_config_loaded; show_paths ;;
  patch-nginx) do_patch_nginx "$@" ;;
  disable-node-renew) do_disable_node_renew ;;
  *) echo "Unknown command: $cmd" >&2; usage; exit 1 ;;
esac
